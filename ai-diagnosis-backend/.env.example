# AI Diagnosis Backend — 本地环境变量模板
#
# 用法：
#   1. 复制为 .env：  cp .env.example .env
#   2. 填入真实值（.env 已被 .gitignore 忽略，不会被提交）
#   3. 启动前 source 加载，或交给 IDE/启动脚本注入环境变量
#
#   bash:   set -a && source .env && set +a && mvn spring-boot:run
#   PowerShell:  Get-Content .env | ForEach-Object { ... }  （或用 IDE 运行配置填环境变量）
#
# 注意：切勿把真实密钥写进 application.yml 的默认值里。

# ===== AI 模型 =====
# 阿里云 DashScope (兼容 OpenAI 协议) 的 API Key
AI_API_KEY=
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
AI_CHAT_MODEL=qwen-plus
AI_CHAT_TEMPERATURE=0.1
AI_EMBEDDING_MODEL=text-embedding-v3

# ===== MySQL =====
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=ai_diagnosis
MYSQL_USERNAME=root
MYSQL_PASSWORD=

# ===== 日志（可选） =====
# LOG_PATH=logs
# LOG_LEVEL_ROOT=INFO
# LOG_LEVEL_APP=INFO
# Spring AI 工具调用内部过程日志，排查 Agent 行为时设为 DEBUG
# LOG_LEVEL_SPRING_AI=INFO

# ===== SQL 诊断证据门禁（可选） =====
# trace 调用链中 MyBatis/JDBC 节点耗时占比/绝对耗时达到阈值才允许进入 SQL 诊断。
# DIAGNOSIS_SQL_EVIDENCE_MIN_COST_PERCENT=30
# DIAGNOSIS_SQL_EVIDENCE_MIN_COST_MILLIS=100

# ===== AI 诊断参数（可选） =====
# DIAGNOSIS_AI_ENABLE=true
# DIAGNOSIS_AI_MAX_ARTHAS_OUTPUT_LENGTH=30000
# DIAGNOSIS_AI_PER_COMMAND_OUTPUT_LIMIT=8000
# DIAGNOSIS_AI_INTENT_TEMPERATURE=0
# DIAGNOSIS_AI_REPORT_TEMPERATURE=0.1
# DIAGNOSIS_AI_MIN_CONFIDENCE=0.6

# ===== Arthas 网关（可选） =====
# DIAGNOSIS_ARTHAS_CONNECT_TIMEOUT_MS=3000
# DIAGNOSIS_ARTHAS_READ_TIMEOUT_MS=60000
# DIAGNOSIS_ARTHAS_MAX_OUTPUT_LENGTH=20000
# DIAGNOSIS_ARTHAS_AUDIT_OUTPUT_EXCERPT_LENGTH=4000
# Arthas Tunnel Server：TUNNEL 模式实例统一通过该 WebSocket 地址按 agentId 路由。
DIAGNOSIS_ARTHAS_TUNNEL_WS_URL=ws://127.0.0.1:7777/ws
DIAGNOSIS_ARTHAS_TUNNEL_WEB_URL=http://127.0.0.1:8080
# 仅供开发/测试诊断沙箱。开启后 AI 可以执行原生 Arthas 命令，包括 watch/ognl 等高权限命令。
DIAGNOSIS_ARTHAS_UNRESTRICTED_AI_COMMANDS_ENABLED=false
DIAGNOSIS_ARTHAS_UNRESTRICTED_AI_ENVIRONMENTS=dev,test
# DIAGNOSIS_ARTHAS_UNRESTRICTED_AI_MAX_COMMAND_LENGTH=4000
# DIAGNOSIS_ARTHAS_UNRESTRICTED_AI_MAX_CALLS_PER_TASK=12
# DIAGNOSIS_ARTHAS_UNRESTRICTED_AI_EXEC_TIMEOUT_MS=90000

# ===== SQL Explain 联合诊断 =====
DIAGNOSIS_SQL_ENABLED=true
# 数据源管理写接口默认关闭；开启后必须设置令牌和加密密钥。
DIAGNOSIS_SQL_ADMIN_ENABLED=false
DIAGNOSIS_SQL_ADMIN_TOKEN=
DIAGNOSIS_SQL_ENCRYPTION_KEY=
# SQL 数据源与 App Instance 密码加密共用此密钥（AES-GCM）。
# DIAGNOSIS_SQL_MAX_LENGTH=20000
# DIAGNOSIS_SQL_CONNECT_TIMEOUT_MS=3000
# DIAGNOSIS_SQL_VALIDATION_TIMEOUT_MS=2000
# DIAGNOSIS_SQL_QUERY_TIMEOUT_SECONDS=15
# DIAGNOSIS_SQL_MAX_POOL_SIZE=3

# ===== App Instance 管理 =====
# 服务实例（Arthas HTTP / Tunnel 接入）管理写接口；开启后必须设置管理令牌。
DIAGNOSIS_APP_INSTANCE_ADMIN_ENABLED=false
DIAGNOSIS_APP_INSTANCE_ADMIN_TOKEN=
# DIAGNOSIS_APP_INSTANCE_CONNECT_TIMEOUT_MS=3000
# DIAGNOSIS_APP_INSTANCE_READ_TIMEOUT_MS=5000

# ===== RAG 知识库（一期） =====
# 默认关闭；开启后会调用 Embedding API，并使用本地 SimpleVectorStore 文件。
DIAGNOSIS_KB_ENABLED=false
DIAGNOSIS_KB_ADMIN_ENABLED=false
DIAGNOSIS_KB_ADMIN_TOKEN=
# DIAGNOSIS_KB_EMBEDDING_DIM=1024
# DIAGNOSIS_KB_CHUNK_SIZE=500
# DIAGNOSIS_KB_CHUNK_OVERLAP=80
# DIAGNOSIS_KB_TOP_K=5
# DIAGNOSIS_KB_MIN_SCORE=0.55
# DIAGNOSIS_KB_VECTOR_FILE=data/kb-simple-vector-store.json
# 历史诊断报告自动沉淀为知识（source_type=HISTORY_REPORT），按 taskNo 去重。
# DIAGNOSIS_KB_AUTO_INGEST_HISTORY=true
# DIAGNOSIS_KB_HISTORY_MIN_CONTENT_LENGTH=200
